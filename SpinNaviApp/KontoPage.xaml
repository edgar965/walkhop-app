<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpinNaviApp.KontoPage"
             Title="Konto"
             BackgroundColor="#f1f5f9">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Status -->
            <Border StrokeThickness="0" BackgroundColor="White" StrokeShape="RoundRectangle 14" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="StatusTitel" Text="Testkonto" FontSize="18" FontAttributes="Bold" TextColor="#0f172a" />
                    <Label x:Name="StatusZeile" FontSize="13" TextColor="#64748b" />
                    <Label x:Name="KontingentZeile" FontSize="13" TextColor="#64748b" />
                </VerticalStackLayout>
            </Border>

            <!-- Anmelden / Registrieren -->
            <Border x:Name="AuthCard" StrokeThickness="0" BackgroundColor="White" StrokeShape="RoundRectangle 14" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="AuthTitel" Text="Anmelden oder Konto anlegen" FontSize="16" FontAttributes="Bold" TextColor="#0f172a" />
                    <Label Text="Damit deine Aufnahmen und Käufe auf allen Geräten verfügbar sind."
                           FontSize="12" TextColor="#64748b" />
                    <Entry x:Name="EmailFeld" Placeholder="E-Mail" Keyboard="Email" />
                    <Entry x:Name="PasswortFeld" Placeholder="Passwort" IsPassword="True" />
                    <Label x:Name="FehlerLabel" TextColor="#e2231a" FontSize="12" IsVisible="False" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="Anmelden" Clicked="OnLogin"
                                BackgroundColor="#0d9488" TextColor="White" CornerRadius="10" />
                        <Button Grid.Column="1" Text="Registrieren" Clicked="OnRegister"
                                BackgroundColor="#334155" TextColor="White" CornerRadius="10" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button x:Name="AbmeldenBtn" Text="Abmelden" Clicked="OnAbmelden" IsVisible="False"
                    BackgroundColor="#e2231a" TextColor="White" CornerRadius="10" />

            <!-- Tarife -->
            <Border StrokeThickness="0" BackgroundColor="White" StrokeShape="RoundRectangle 14" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Tarife" FontSize="16" FontAttributes="Bold" TextColor="#0f172a" />
                    <Label FontSize="13" TextColor="#334155" Text="• Gratis: 2 Routen pro Tag" />
                    <Label FontSize="13" TextColor="#334155" Text="• Einzelne Route/Suche: 1 €  ·  Paket 10: 3 €" />
                    <Label FontSize="13" TextColor="#334155" Text="• Offline-Karte: 3 €" />
                    <Label FontSize="13" TextColor="#334155" Text="• Premium 5 €/Monat: 3 Offline-Karten + unbegrenzt Suche/GPS" />
                    <Label FontSize="13" TextColor="#334155" Text="• Premium 8 €/Monat: alle Karten, alle Funktionen" />
                    <Button x:Name="KaufenBtn" Text="Premium freischalten" Clicked="OnKaufen"
                            BackgroundColor="#C8102E" TextColor="White" CornerRadius="10" Margin="0,6,0,0" />
                    <Label FontSize="11" TextColor="#94a3b8"
                           Text="In-App-Kauf (App Store / Google Play) bzw. Stripe/PayPal auf spin1more.com." />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
