<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SpinNaviApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SpinNaviApp"
    Title="{x:Static local:AppConfig.Marke}"
    FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="#003153"
    Shell.BackgroundColor="White"
    Shell.TitleColor="#0f172a"
    Shell.ForegroundColor="#0f172a"
    Shell.FlyoutBackgroundColor="#003153">

    <Shell.FlyoutHeaderTemplate>
        <DataTemplate>
            <Grid HeightRequest="120" BackgroundColor="#003153" Padding="20,0">
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Label Text="{x:Static local:AppConfig.Marke}" FontSize="24" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{x:Static local:AppConfig.MarkeUntertitel}" FontSize="13" TextColor="#9fc3d8" />
                </VerticalStackLayout>
            </Grid>
        </DataTemplate>
    </Shell.FlyoutHeaderTemplate>

    <!-- Flyout-Einträge: weiße Schrift auf dem dunkelblauen Hintergrund (sonst kaum lesbar,
         da die Default-Schrift die dunkle Shell.ForegroundColor erbt). Gilt für normale
         Flyout-Items (binden Title) … -->
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid Padding="20,0" HeightRequest="50" BackgroundColor="#003153" ColumnDefinitions="*">
                <Label Text="{Binding Title}" TextColor="White" FontSize="16"
                       VerticalOptions="Center" VerticalTextAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <!-- … und für Menü-Einträge wie „Beenden" (binden Text). -->
    <Shell.MenuItemTemplate>
        <DataTemplate>
            <Grid Padding="20,0" HeightRequest="50" BackgroundColor="#003153" ColumnDefinitions="*">
                <Label Text="{Binding Text}" TextColor="White" FontSize="16"
                       VerticalOptions="Center" VerticalTextAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Shell.MenuItemTemplate>

    <FlyoutItem Title="Start" Route="start">
        <ShellContent ContentTemplate="{DataTemplate local:UebersichtPage}" Route="StartPage" />
    </FlyoutItem>

    <FlyoutItem Title="Navigation" Route="navigation">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="Konto" Route="konto">
        <ShellContent ContentTemplate="{DataTemplate local:KontoPage}" Route="KontoPage" />
    </FlyoutItem>

    <FlyoutItem Title="Einstellungen" Route="einstellungen">
        <ShellContent ContentTemplate="{DataTemplate local:EinstellungenPage}" Route="EinstellungenPage" />
    </FlyoutItem>

    <MenuItem Text="Beenden" Clicked="OnLogout" />

</Shell>
