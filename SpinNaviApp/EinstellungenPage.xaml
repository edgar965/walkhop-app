<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:SpinNaviApp"
             x:Class="SpinNaviApp.EinstellungenPage"
             Title="{loc:Translate nav_einstellungen}"
             BackgroundColor="#f1f5f9">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="StrokeShape" Value="RoundRectangle 14" />
                <Setter Property="Padding" Value="16" />
            </Style>
            <Style x:Key="Sec" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="#94a3b8" />
                <Setter Property="Margin" Value="4,8,0,0" />
            </Style>
            <Style x:Key="RowT" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="TextColor" Value="#0f172a" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <Style x:Key="RowS" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="#94a3b8" />
            </Style>
            <Style x:Key="Chev" TargetType="Label">
                <Setter Property="Text" Value="›" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="TextColor" Value="#cbd5e1" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <Style TargetType="Switch">
                <Setter Property="OnColor" Value="#22c55e" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <Style x:Key="Trenner" TargetType="BoxView">
                <Setter Property="HeightRequest" Value="1" />
                <Setter Property="Color" Value="#eef2f6" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Tab-Leiste (Segmented) – nutzt das Standard-Template (Hamburger + Titel der Shell-NavBar) -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="12,12,12,4" Padding="4"
                BackgroundColor="#e2e8f0" StrokeShape="RoundRectangle 12">
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="2">
                <Border x:Name="SegAllg" Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,9">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTab" CommandParameter="allgemein" />
                    </Border.GestureRecognizers>
                    <Label x:Name="LblAllg" Text="{loc:Translate einst_tab_allgemein}" FontSize="13" HorizontalOptions="Center"
                           VerticalOptions="Center" LineBreakMode="TailTruncation" />
                </Border>
                <Border x:Name="SegNavi" Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,9">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTab" CommandParameter="navigation" />
                    </Border.GestureRecognizers>
                    <Label x:Name="LblNavi" Text="{loc:Translate einst_tab_navigation}" FontSize="13" HorizontalOptions="Center"
                           VerticalOptions="Center" LineBreakMode="TailTruncation" />
                </Border>
                <Border x:Name="SegKarte" Grid.Column="2" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,9">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTab" CommandParameter="karte" />
                    </Border.GestureRecognizers>
                    <Label x:Name="LblKarte" Text="{loc:Translate einst_tab_karte}" FontSize="13" HorizontalOptions="Center"
                           VerticalOptions="Center" LineBreakMode="TailTruncation" />
                </Border>
                <Border x:Name="SegKonto" Grid.Column="3" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,9">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTab" CommandParameter="anmeldung" />
                    </Border.GestureRecognizers>
                    <Label x:Name="LblKonto" Text="{loc:Translate einst_tab_anmeldung}" FontSize="13" HorizontalOptions="Center"
                           VerticalOptions="Center" LineBreakMode="TailTruncation" />
                </Border>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <Grid Padding="12,8,12,16">

                <!-- ================= Tab 1: Allgemein ================= -->
                <VerticalStackLayout x:Name="TabAllgemein" Spacing="12">
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_app_sprache}" Style="{StaticResource RowT}" />
                                    <Label x:Name="SpracheWert" Style="{StaticResource RowS}" Text="Deutsch" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Style="{StaticResource Chev}" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSpracheWechseln" />
                                </Grid.GestureRecognizers>
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_einheiten}" Style="{StaticResource RowT}" />
                                    <Label x:Name="EinheitenWert" Style="{StaticResource RowS}" Text="Metrisch (km, m)" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Style="{StaticResource Chev}" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnEinheitenWechseln" />
                                </Grid.GestureRecognizers>
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_bildschirm_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_bildschirm_sub}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="BildschirmSchalter" Toggled="OnBildschirm" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_kompakt_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_kompakt_sub}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="KompaktSchalter" Toggled="OnKompakt" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_autotrack_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_autotrack_sub}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="AufnahmeSchalter" Toggled="OnAutoAufnahme" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_fotosstart_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_fotosstart_sub}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="FotosStartSchalter" Toggled="OnFotosStart" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <Label Grid.Column="0" Text="{loc:Translate einst_fotoswlan_titel}" Style="{StaticResource RowT}" />
                                <Switch Grid.Column="1" x:Name="FotosWlanSchalter" Toggled="OnFotosWlan" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ================= Tab 2: Navigation ================= -->
                <VerticalStackLayout x:Name="TabNavigation" Spacing="12" IsVisible="False">
                    <Label Text="{loc:Translate einst_sec_fortbewegung}" Style="{StaticResource Sec}" />
                    <Border Style="{StaticResource Card}" Padding="4" BackgroundColor="#e2e8f0" StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="2">
                            <Border x:Name="PfFuss" Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFortbewegung" CommandParameter="pedestrian" /></Border.GestureRecognizers>
                                <Label x:Name="LblPfFuss" Text="{loc:Translate prof_fuss}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                            <Border x:Name="PfRad" Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFortbewegung" CommandParameter="bicycle" /></Border.GestureRecognizers>
                                <Label x:Name="LblPfRad" Text="{loc:Translate prof_rad}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                            <Border x:Name="PfAuto" Grid.Column="2" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFortbewegung" CommandParameter="auto" /></Border.GestureRecognizers>
                                <Label x:Name="LblPfAuto" Text="{loc:Translate prof_auto}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <Label Text="{loc:Translate einst_sec_wegtyp}" Style="{StaticResource Sec}" />
                    <Border Style="{StaticResource Card}" Padding="4" BackgroundColor="#e2e8f0" StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="2">
                            <Border x:Name="WtFest" Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnWegtypEinst" CommandParameter="fest" /></Border.GestureRecognizers>
                                <Label x:Name="LblWtFest" Text="{loc:Translate wegtyp_fest}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                            <Border x:Name="WtNeutral" Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnWegtypEinst" CommandParameter="neutral" /></Border.GestureRecognizers>
                                <Label x:Name="LblWtNeutral" Text="{loc:Translate wegtyp_neutral}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                            <Border x:Name="WtNatur" Grid.Column="2" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnWegtypEinst" CommandParameter="natur" /></Border.GestureRecognizers>
                                <Label x:Name="LblWtNatur" Text="{loc:Translate wegtyp_natur}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <Label Text="{loc:Translate einst_sec_routenoptionen}" Style="{StaticResource Sec}" />
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_autobahn_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_gilt_auto}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="AutobahnSchalter" Toggled="OnAutobahnEinst" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_unbefestigt_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_gilt_auto}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="UnbefestigtSchalter" Toggled="OnUnbefestigtEinst" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_oberflaeche_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_gilt_rad}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="OberflaecheSchalter" Toggled="OnOberflaecheEinst" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{loc:Translate einst_sec_farbmodus}" Style="{StaticResource Sec}" />
                    <Border Style="{StaticResource Card}" Padding="4" BackgroundColor="#e2e8f0" StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="2">
                            <Border x:Name="FmAuto" Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFarbmodus" CommandParameter="auto" /></Border.GestureRecognizers>
                                <Label x:Name="LblFmAuto" Text="{loc:Translate farb_auto}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                            <Border x:Name="FmTag" Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFarbmodus" CommandParameter="tag" /></Border.GestureRecognizers>
                                <Label x:Name="LblFmTag" Text="{loc:Translate farb_tag}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                            <Border x:Name="FmNacht" Grid.Column="2" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFarbmodus" CommandParameter="nacht" /></Border.GestureRecognizers>
                                <Label x:Name="LblFmNacht" Text="{loc:Translate farb_nacht}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <Label Text="{loc:Translate einst_sec_tonsprache}" Style="{StaticResource Sec}" />
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <Label Grid.Column="0" Text="{loc:Translate einst_sprachnavi}" Style="{StaticResource RowT}" />
                                <Switch Grid.Column="1" x:Name="SprachnaviSchalter" Toggled="OnSprachnavi" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <VerticalStackLayout Spacing="6" Padding="0,12">
                                <Label Text="{loc:Translate einst_lautstaerke}" Style="{StaticResource RowT}" />
                                <Slider x:Name="LautstaerkeSlider" Minimum="0" Maximum="1"
                                        MinimumTrackColor="#22c55e" ThumbColor="White"
                                        ValueChanged="OnLautstaerke" />
                            </VerticalStackLayout>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_benachr_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_benachr_sub}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="BenachrichtigungSchalter" Toggled="OnBenachrichtigung" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_navisprache}" Style="{StaticResource RowT}" />
                                    <Label x:Name="NaviSpracheWert" Style="{StaticResource RowS}" Text="Deutsch" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Style="{StaticResource Chev}" />
                                <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnNaviSpracheWechseln" /></Grid.GestureRecognizers>
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_bluetooth_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_bluetooth_standard}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Style="{StaticResource Chev}" />
                                <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnBluetooth" /></Grid.GestureRecognizers>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{loc:Translate einst_sec_kartenansicht}" Style="{StaticResource Sec}" />
                    <Border Style="{StaticResource Card}" Padding="4" BackgroundColor="#e2e8f0" StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="2">
                            <Border x:Name="KaGeneigt" Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnKartenansicht" CommandParameter="3d" /></Border.GestureRecognizers>
                                <Label x:Name="LblKaGeneigt" Text="{loc:Translate ka_geneigt}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                            <Border x:Name="Ka2d" Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnKartenansicht" CommandParameter="2d" /></Border.GestureRecognizers>
                                <Label x:Name="LblKa2d" Text="{loc:Translate ka_2d}" FontSize="13" HorizontalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- ================= Tab 3: Karte ================= -->
                <VerticalStackLayout x:Name="TabKarte" Spacing="12" IsVisible="False">
                    <Label Text="{loc:Translate einst_sec_kartenmodus}" Style="{StaticResource Sec}" />
                    <Border Style="{StaticResource Card}" Padding="4" BackgroundColor="#e2e8f0" StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="2">
                            <Border x:Name="KmWandern" Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnKartenmodus" CommandParameter="Wandern" /></Border.GestureRecognizers>
                                <Label x:Name="LblKmWandern" Text="{loc:Translate km_wandern}" FontSize="12" HorizontalOptions="Center" LineBreakMode="TailTruncation" />
                            </Border>
                            <Border x:Name="KmStandard" Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnKartenmodus" CommandParameter="Standard" /></Border.GestureRecognizers>
                                <Label x:Name="LblKmStandard" Text="{loc:Translate km_standard}" FontSize="12" HorizontalOptions="Center" LineBreakMode="TailTruncation" />
                            </Border>
                            <Border x:Name="KmSatellit" Grid.Column="2" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnKartenmodus" CommandParameter="Satellit" /></Border.GestureRecognizers>
                                <Label x:Name="LblKmSatellit" Text="{loc:Translate km_satellit}" FontSize="12" HorizontalOptions="Center" LineBreakMode="TailTruncation" />
                            </Border>
                            <Border x:Name="KmDunkel" Grid.Column="3" StrokeThickness="0" StrokeShape="RoundRectangle 9" Padding="0,10">
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnKartenmodus" CommandParameter="Dunkel" /></Border.GestureRecognizers>
                                <Label x:Name="LblKmDunkel" Text="{loc:Translate km_dunkel}" FontSize="12" HorizontalOptions="Center" LineBreakMode="TailTruncation" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{loc:Translate einst_overlay_titel}" Style="{StaticResource RowT}" />
                                <Label Text="{loc:Translate einst_overlay_sub}" Style="{StaticResource RowS}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" x:Name="OverlaySchalter" Toggled="OnOverlay" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_relief_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_nur_online}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="ReliefSchalter" Toggled="OnRelief" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_hangneigung_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_hangneigung_sub}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="HangneigungSchalter" Toggled="OnHangneigung" />
                            </Grid>
                            <BoxView Style="{StaticResource Trenner}" />
                            <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{loc:Translate einst_drehung_titel}" Style="{StaticResource RowT}" />
                                    <Label Text="{loc:Translate einst_drehung_sub}" Style="{StaticResource RowS}" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="DrehungSchalter" Toggled="OnDrehung" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{loc:Translate einst_sec_standardpunkt}" Style="{StaticResource Sec}" />
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{loc:Translate einst_standardpunkt_info}"
                                   FontSize="12" TextColor="#94a3b8" />
                            <Label x:Name="StandardPunktLabel" FontSize="14" TextColor="#0f172a" />
                            <Button x:Name="StandardAufPositionBtn" Text="{loc:Translate einst_standort_uebernehmen}" Clicked="OnStandardAufPosition"
                                    BackgroundColor="#0d9488" TextColor="White" CornerRadius="10" />
                            <Button Text="{loc:Translate einst_zuruecksetzen_bbtor}" Clicked="OnStandardZuruecksetzen"
                                    BackgroundColor="#64748b" TextColor="White" CornerRadius="10" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{loc:Translate einst_sec_offline}" Style="{StaticResource Sec}" />
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="CacheLabel" Text="Zwischenspeicher: –" FontSize="13" TextColor="#64748b" />
                            <Label Text="{loc:Translate einst_offline_info}"
                                   FontSize="12" TextColor="#94a3b8" />
                            <!-- Vordefinierte Region offline speichern (Kacheln + verkleinerte Fotos der Region) -->
                            <Button x:Name="RegionLadenBtn" AutomationId="offline_region" Text="{loc:Translate einst_region_laden_btn}" Clicked="OnRegionLaden"
                                    BackgroundColor="#0d9488" TextColor="White" CornerRadius="10" />
                            <!-- Umgebung (~3 km um den Standort) offline vorladen -->
                            <Button x:Name="OfflineLadenBtn" AutomationId="offline_laden" Text="{loc:Translate einst_offline_laden_btn}" Clicked="OnOfflineLaden"
                                    BackgroundColor="#16a34a" TextColor="White" CornerRadius="10" />
                            <!-- Liste der gespeicherten Offline-Pakete (Regionen/Touren) -->
                            <Label Text="{loc:Translate offline_pakete_titel}" FontSize="13" FontAttributes="Bold" TextColor="#475569" Margin="0,4,0,0" />
                            <VerticalStackLayout x:Name="OfflinePaketeBox" Spacing="6" />
                            <Button Text="{loc:Translate einst_cache_leeren_btn}" Clicked="OnCacheLeeren"
                                    BackgroundColor="#e2231a" TextColor="White" CornerRadius="10" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ================= Tab 4: Anmeldung / Premium ================= -->
                <VerticalStackLayout x:Name="TabAnmeldung" Spacing="12" IsVisible="False">
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="StatusTitel" Text="Konto" FontSize="18" FontAttributes="Bold" TextColor="#0f172a" />
                            <Label x:Name="StatusZeile" FontSize="13" TextColor="#64748b" />
                            <Label x:Name="KontingentZeile" FontSize="13" TextColor="#64748b" />
                        </VerticalStackLayout>
                    </Border>

                    <Border x:Name="AuthCard" Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="10">
                            <Label x:Name="AuthTitel" Text="Konto anlegen oder anmelden" FontSize="16" FontAttributes="Bold" TextColor="#0f172a" />
                            <Entry x:Name="VornameFeld" Placeholder="{loc:Translate feld_vorname}" />
                            <Entry x:Name="NameFeld" Placeholder="{loc:Translate feld_name}" />
                            <Entry x:Name="EmailFeld" Placeholder="{loc:Translate feld_email}" Keyboard="Email" />
                            <Entry x:Name="PasswortFeld" Placeholder="{loc:Translate feld_passwort}" IsPassword="True" />
                            <Label x:Name="FehlerLabel" TextColor="#e2231a" FontSize="13" IsVisible="False" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0" Text="{loc:Translate btn_anmelden}" Clicked="OnLogin"
                                        BackgroundColor="#0d9488" TextColor="White" CornerRadius="10" />
                                <Button Grid.Column="1" Text="{loc:Translate btn_registrieren}" Clicked="OnRegister"
                                        BackgroundColor="#003153" TextColor="White" CornerRadius="10" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Button x:Name="PremiumBtn" Text="{loc:Translate btn_premium_freischalten}" Clicked="OnKaufen"
                            BackgroundColor="#f59e0b" TextColor="White" CornerRadius="10" />
                    <Button x:Name="AbmeldenBtn" Text="{loc:Translate btn_abmelden}" Clicked="OnAbmelden"
                            BackgroundColor="#e2e8f0" TextColor="#0f172a" CornerRadius="10" IsVisible="False" />

                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate ueber_titel}" FontSize="16" FontAttributes="Bold" TextColor="#0f172a" />
                            <Label x:Name="VersionLabel" FontSize="13" TextColor="#64748b" />
                            <Label x:Name="ServerLabel" FontSize="13" TextColor="#64748b" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
